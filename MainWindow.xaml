<Window x:Class="InstaCurator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="InstaCurator - Agência IA" Height="800" Width="1300"
        WindowStartupLocation="CenterScreen" Background="#121212" WindowState="Maximized"
        FontFamily="Segoe UI, Tahoma, Geneva, Verdana, sans-serif">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#3B82F6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Padding" Value="5"/>
        </Style>
    </Window.Resources>
  <Grid>
    <TabControl Background="#121212" BorderThickness="0" Foreground="White">

        <TabItem Header="📱 Instagram" Width="120" Height="30">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                    <TextBlock Text="Rival (@):" VerticalAlignment="Center" Foreground="White" Margin="0,0,10,0"/>
                    <TextBox x:Name="TxtRival" Width="150" Height="28" Margin="0,0,10,0"/>
                    <Button Content="Salvar Rival" Click="BtnSalvarRival_Click" Width="90" Height="28" Background="#333" Margin="0,0,10,0"/>

                    <ComboBox x:Name="ListaRivais" Width="150" Height="28" SelectionChanged="ListaRivais_SelectionChanged" Margin="0,0,20,0"/>

                    <TextBlock Text="Mín. Likes: (Não funciona ainda deixe 0)" VerticalAlignment="Center" Foreground="White" Margin="0,0,10,0"/>
                    <TextBox x:Name="TxtMinLikes" Width="80" Height="28" Text="0" Margin="0,0,20,0"/>

                    <Button x:Name="BtnBuscar" Content="Buscar Instagram 🔍" Click="BtnBuscar_Click" Width="150" Height="30" Background="#10B981"/>
                    <Button Content="Limpar Feed" Click="BtnLimparFeed_Click" Width="100" Height="30" Margin="10,0,0,0" Background="#EF4444"/>
                </StackPanel>

                <ListBox x:Name="ListaPosts" Grid.Row="1" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel IsItemsHost="True" Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Width="250" Height="350" Background="#1E1E1E" CornerRadius="8" Margin="10" BorderBrush="#333" BorderThickness="1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="200"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Border CornerRadius="8,8,0,0" ClipToBounds="True">
                                        <Image Source="{Binding CaminhosDasImagens[0]}" Stretch="UniformToFill"/>
                                    </Border>
                                    <StackPanel Grid.Row="1" Margin="10">
                                        <TextBlock Text="{Binding PaginaRival}" FontWeight="Bold" Foreground="#10B981"/>
                                        <TextBlock Text="{Binding QuantidadeLikes, StringFormat='{}❤️ {0} likes'}" Foreground="#AAA" Margin="0,2,0,10"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Content="Aprovar 🚀" Click="BtnAprovar_Click" Width="75" Height="28" Margin="0,0,5,0" Background="#2563EB"/>
                                            <Button Content="Ver Link" Click="BtnAbrirLink_Click" Width="65" Height="28" Margin="0,0,5,0" Background="#444"/>
                                            <Button Content="Lixo" Click="BtnDescartar_Click" Width="50" Height="28" Background="#EF4444"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </TabItem>

        <TabItem Header="📌 Pinterest" Width="120" Height="30">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                    <TextBlock Text="Busca:" VerticalAlignment="Center" Foreground="White" Margin="0,0,10,0"/>
                    <TextBox x:Name="TxtBuscaPinterest" Width="200" Height="28" Margin="0,0,10,0"/>
                    <Button x:Name="BtnBuscarPinterest" Content="Buscar Pins 📌" Click="BtnBuscarPinterest_Click" Width="120" Height="30" Background="#E60023"/>
                </StackPanel>

                <ListBox x:Name="ListaPins" Grid.Row="1" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel IsItemsHost="True" Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Width="200" Height="300" Background="#1E1E1E" CornerRadius="8" Margin="10" BorderBrush="#333" BorderThickness="1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="240"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Border CornerRadius="8,8,0,0" ClipToBounds="True">
                                        <Image Source="{Binding CaminhosDasImagens[0]}" Stretch="UniformToFill"/>
                                    </Border>
                                    <Button Grid.Row="1" Content="Telegram 🚀" Click="BtnEnviarPin_Click" Height="30" Margin="10" Background="#2563EB"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </TabItem>

        <TabItem Header="🧠 Curiosidades" Width="150" Height="30">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                    <TextBlock Text="Página:" VerticalAlignment="Center" Foreground="White" Margin="0,0,5,0" FontWeight="Bold"/>
                    <ComboBox x:Name="CmbPagina" Width="160" Height="28" Margin="0,0,15,0" SelectedIndex="0">
                        <ComboBoxItem Content="Explicando em Imagens"/>
                        <ComboBoxItem Content="Ensinando Curiosidades"/>
                    </ComboBox>

                    <TextBlock Text="Tom:" VerticalAlignment="Center" Foreground="White" Margin="0,0,5,0" FontWeight="Bold"/>
                    <ComboBox x:Name="CmbTom" Width="130" Height="28" Margin="0,0,15,0" SelectedIndex="0">
                        <ComboBoxItem Content="Normal / Informativo"/>
                        <ComboBoxItem Content="Clickbait / Extremo"/>
                        <ComboBoxItem Content="Sombrio / Misterioso"/>
                        <ComboBoxItem Content="Emocional / Delicado"/>
                    </ComboBox>

                    <TextBlock Text="Imagens:" VerticalAlignment="Center" Foreground="White" Margin="0,0,5,0" FontWeight="Bold"/>
                    <ComboBox x:Name="CmbFonteImagem" Width="120" Height="28" Margin="0,0,15,0" SelectedIndex="0">
                        <ComboBoxItem Content="Pexels (Fotos)"/>
                        <ComboBoxItem Content="IA (Gerada)"/>
                        <ComboBoxItem Content="Unsplash (Fotos)"/>
                    </ComboBox>

                    <TextBlock Text="Tema:" VerticalAlignment="Center" Foreground="White" Margin="0,0,5,0" FontWeight="Bold"/>
                    <TextBox x:Name="TxtTemaCuriosidade" Width="200" Height="28" Margin="0,0,10,0"/>

                    <Button x:Name="BtnGerarRoteiroBase" Content="1. Gerar Roteiro Base ✨" Click="BtnGerarRoteiroBase_Click" Width="170" Height="30" Background="#8B5CF6"/>
                </StackPanel>

                <Grid Grid.Row="1" x:Name="GridEditorTrabalho" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="330"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Margin="0,0,10,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <ListBox x:Name="ListaSlidesEditor" Grid.Row="0" Background="#1E1E1E" BorderThickness="0" Foreground="White" SelectionChanged="ListaSlidesEditor_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding NomeSlide}" Padding="10" FontSize="14" FontWeight="Bold"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <StackPanel Grid.Row="1" Margin="0,10,0,0">
                            <TextBlock Text="Legenda do Post:" Foreground="#E0E0E0" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBox x:Name="TxtLegendaGlobal" TextWrapping="Wrap" AcceptsReturn="True" Height="120" Padding="5"/>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Column="1" Background="#1E1E1E" CornerRadius="8" Padding="15">
                        <Viewbox Stretch="Uniform">
                            <Grid Width="1080" Height="1350" Background="Black">
                                <Canvas ClipToBounds="True" Width="1080" Height="1350" Background="Transparent"
                                        MouseLeftButtonDown="PreviewCanvas_MouseDown"
                                        MouseLeftButtonUp="PreviewCanvas_MouseUp"
                                        MouseMove="PreviewCanvas_MouseMove"
                                        MouseLeave="PreviewCanvas_MouseLeave">

                                    <Image x:Name="PreviewImagemFundo" Stretch="Fill">
                                        <Image.RenderTransform>
                                            <TranslateTransform x:Name="ImageTranslate" X="0" Y="0"/>
                                        </Image.RenderTransform>
                                    </Image>
                                </Canvas>

                                <Border x:Name="AvisoImagemFixa" Background="#CC000000" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,50,0,0" Padding="20,10" CornerRadius="10" Visibility="Collapsed" IsHitTestVisible="False">
                                    <TextBlock Text="🔒 Fundo de tamanho exato (Não move)" Foreground="#FBBF24" FontSize="24" FontWeight="Bold"/>
                                </Border>

                                <Border IsHitTestVisible="False">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="Transparent" Offset="0.30"/>
                                            <GradientStop Color="Black" Offset="0.60"/>
                                            <GradientStop Color="Black" Offset="1.0"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>

                                <StackPanel VerticalAlignment="Top" Margin="43,1010,43,0" IsHitTestVisible="False">
                                    <TextBlock x:Name="PreviewTextoPrincipal" FontSize="50" FontWeight="Bold" Foreground="White" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,30"/>
                                    <TextBlock x:Name="PreviewSubtitulo" FontSize="40" FontWeight="Bold" Foreground="White" TextWrapping="Wrap" TextAlignment="Center" Visibility="Collapsed"/>
                                </StackPanel>

                                <TextBlock Text="ARRASTE ⇒" FontSize="30" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,50" IsHitTestVisible="False"/>
                            </Grid>
                        </Viewbox>
                    </Border>

                    <Border Grid.Column="2" Background="#1E1E1E" CornerRadius="8" Margin="10,0,0,0" Padding="15">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="0,0,5,0">
                                <TextBlock x:Name="LblTituloPainel" Text="EDITANDO: CAPA" Foreground="#10B981" FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>

                                <TextBlock Text="Texto do Slide:" Foreground="White" Margin="0,0,0,5"/>
                                <TextBox x:Name="EditorTextoSlide" Height="100" TextWrapping="Wrap" AcceptsReturn="True" TextChanged="EditorCampos_TextChanged"/>

                                <TextBlock Text="Não gostou? Peça para a IA alterar:" Foreground="#AAA" FontSize="11" Margin="0,8,0,2"/>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TxtFeedbackIA" Grid.Column="0" Height="28" ToolTip="Ex: Tira a parte da coroa"/>
                                    <Button x:Name="BtnRefinarTexto" Grid.Column="1" Content="Refazer 🪄" Click="BtnRefinarTexto_Click" Width="80" Margin="5,0,0,0" Background="#8B5CF6"/>
                                </Grid>

                                <StackPanel x:Name="PainelSubtitulo" Visibility="Collapsed">
                                    <TextBlock Text="Subtítulo (Só na Capa):" Foreground="White" Margin="0,5,0,5"/>
                                    <TextBox x:Name="EditorSubtituloSlide" Height="50" TextWrapping="Wrap" AcceptsReturn="True" TextChanged="EditorCampos_TextChanged"/>
                                </StackPanel>

                                <TextBlock Text="Keyword IA para o Fundo (Inglês):" Foreground="White" FontWeight="Bold" Margin="0,15,0,5"/>
                                <TextBox x:Name="EditorKeywordSlide" Height="28" TextChanged="EditorCampos_TextChanged"/>
                                <Button x:Name="BtnSugerirKeyword" Content="🧠 IA: Sugerir Nova Keyword" Margin="0,5,0,0" Background="#444" Height="30" Click="BtnSugerirKeyword_Click"/>

                                <TextBlock Text="Busca Manual de Imagem Real (Bing):" Foreground="#AAA" FontSize="11" Margin="0,15,0,2"/>
                                <Grid Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TxtBuscaManualImagem" Grid.Column="0" Height="28" ToolTip="Ex: Neymar PSG"/>
                                    <Button x:Name="BtnBuscaManualImagem" Grid.Column="1" Content="Buscar 🔍" Click="BtnBuscaManualImagem_Click" Width="80" Margin="5,0,0,0" Background="#F59E0B"/>
                                </Grid>

                                <Button x:Name="BtnTrocarFundo" Content="🔄 Baixar Fundo (Keyword da IA)" Margin="0,10,0,0" Background="#10B981" Height="35" Click="BtnTrocarFundo_Click"/>

                                <Button x:Name="BtnUploadFundoLocal" Content="📁 Subir Imagem do PC" Margin="0,5,0,0" Background="#444" Height="35" Click="BtnUploadFundoLocal_Click"/>

                                <Border BorderBrush="#333" BorderThickness="0,1,0,0" Margin="0,20,0,20"/>

                                <Button x:Name="BtnFinalizarCarrossel" Content="2. Assar Imagens e Enviar 🚀" Click="BtnFinalizarCarrossel_Click" Height="45" Background="#2563EB" FontSize="14"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>
        </TabItem>
    </TabControl>

        <Grid x:Name="OverlayProgresso" Visibility="Collapsed" Background="#D8000000" Panel.ZIndex="100">
            <Border Background="#1E1E1E" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="30" CornerRadius="12" BorderBrush="#333" BorderThickness="1" MinWidth="350">
                <StackPanel>
                    <TextBlock Text="⚙️ TRABALHANDO..." Foreground="#10B981" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                    <TextBlock x:Name="TxtProgressoStatus" Text="Gerando roteiro com a IA..." Foreground="White" FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                    <ProgressBar x:Name="BarraProgresso" Height="15" Minimum="0" Maximum="100" Value="0" Foreground="#2563EB" Background="#333" BorderThickness="0" Margin="0,0,0,10"/>

                    <TextBlock x:Name="TxtProgressoTempo" Text="Estimativa: Calculando..." Foreground="#AAA" FontSize="12" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>